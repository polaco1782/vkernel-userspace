<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>
  <PropertyGroup Label="Globals">
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <RootNamespace>modplay</RootNamespace>
    <ProjectName>modplay</ProjectName>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <!--
    Freestanding PE32+ userspace application for vkernel.
    The kernel PE loader maps sections and applies DIR64 base
    relocations; the binary must be compiled without any CRT.

    ABI: MSVC MS-x64 calling convention matches the kernel perfectly.
    The kernel calls entry(api) with api in RCX; MSVC userspace reads
    from RCX with no bridging required.

    NOTE: No SDL, no argp, no gettimeofday — vkernel audio/input APIs only.
  -->
  <PropertyGroup Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
  </PropertyGroup>
  <Import Project="$(ProjectDir)..\llvm_userspace.props" />
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <PropertyGroup>
    <OutDir>$(ProjectDir)..\..\build_clang\modplay\$(Configuration)\</OutDir>
    <IntDir>$(ProjectDir)..\..\build_clang\modplay\obj\$(Configuration)\</IntDir>
    <TargetName>modplay</TargetName>
    <TargetExt>.vbin</TargetExt>
  </PropertyGroup>
  <PropertyGroup>
    <ClangClAdditionalOptions>$(ClangClAdditionalOptions) /clang:-fno-exceptions /clang:-fno-rtti /clang:-nostdinc++</ClangClAdditionalOptions>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <CompileAs>Default</CompileAs>
      <AdditionalIncludeDirectories>$(ProjectDir)..\libc;$(ProjectDir)..\newlib\newlib\libc\include;$(ProjectDir)..\include;$(ProjectDir)..\cpp\include;$(ProjectDir)..\..\include;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <PreprocessorDefinitions>VK_BUILD_FOR_USERSPACE=1;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <ExceptionHandling>false</ExceptionHandling>
      <RuntimeTypeInfo>false</RuntimeTypeInfo>
      <AdditionalOptions>/GR- /EHs-c- %(AdditionalOptions)</AdditionalOptions>
    </ClCompile>
  </ItemDefinitionGroup>
  <ItemGroup>
    <ClCompile Include="..\libc\crt0.c">
      <CompileAs>CompileAsC</CompileAs>
    </ClCompile>
    <ClCompile Include="main_vk.cpp">
      <CompileAs>CompileAsCpp</CompileAs>
    </ClCompile>
    <ClCompile Include="..\cpp\runtime\cxx_runtime.cpp">
      <CompileAs>CompileAsCpp</CompileAs>
    </ClCompile>
    <ClCompile Include="..\cpp\runtime\iostream.cpp">
      <CompileAs>CompileAsCpp</CompileAs>
    </ClCompile>
    <ClCompile Include="libmodplay\effects.c" />
    <ClCompile Include="libmodplay\envelope.c" />
    <ClCompile Include="libmodplay\mixer.c" />
    <ClCompile Include="libmodplay\mod.c" />
    <ClCompile Include="libmodplay\modplay.c" />
    <ClCompile Include="libmodplay\modplay_core.c" />
    <ClCompile Include="libmodplay\s3m.c" />
    <ClCompile Include="libmodplay\xm.c" />
  </ItemGroup>
  <ItemGroup>
    <ClInclude Include="libmodplay\defines.h" />
    <ClInclude Include="libmodplay\effects.h" />
    <ClInclude Include="libmodplay\envelope.h" />
    <ClInclude Include="libmodplay\mixer.h" />
    <ClInclude Include="libmodplay\mod.h" />
    <ClInclude Include="libmodplay\modplay.h" />
    <ClInclude Include="libmodplay\modplay_core.h" />
    <ClInclude Include="libmodplay\s3m.h" />
    <ClInclude Include="libmodplay\xm.h" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\libc\libc.vcxproj">
      <Project>{7C8D9E0F-1234-4B5C-89DE-0123456789AC}</Project>
      <LinkLibraryDependencies>true</LinkLibraryDependencies>
      <UseLibraryDependencyInputs>true</UseLibraryDependencyInputs>
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
    </ProjectReference>
  </ItemGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>
