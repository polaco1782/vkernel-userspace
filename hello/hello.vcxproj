<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>
  <PropertyGroup Label="Globals">
    <ProjectGuid>{5F2D6A2B-8AE1-4A4D-9C1A-4D9E6E3D7B20}</ProjectGuid>
    <RootNamespace>hello</RootNamespace>
    <ProjectName>hello</ProjectName>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <!--
    Freestanding PE32+ userspace application for vkernel.
    The kernel PE loader maps sections and applies DIR64 base
    relocations; the binary must be compiled without any CRT.

    ABI: MSVC MS-x64 calling convention matches the kernel perfectly.
    The kernel calls entry(api) with api in RCX; MSVC userspace reads
    from RCX with no bridging required.
  -->
  <PropertyGroup Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
  </PropertyGroup>
  <Import Project="$(ProjectDir)..\llvm_userspace.props" />
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <PropertyGroup>
    <OutDir>$(ProjectDir)..\..\build_clang\hello\$(Configuration)\</OutDir>
    <IntDir>$(ProjectDir)..\..\build_clang\hello\obj\$(Configuration)\</IntDir>
    <TargetName>hello</TargetName>
    <TargetExt>.vbin</TargetExt>
  </PropertyGroup>
  <PropertyGroup>
    <ClangClAdditionalOptions>$(ClangClAdditionalOptions) /clang:-std=c17</ClangClAdditionalOptions>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <CompileAs>CompileAsC</CompileAs>
      <AdditionalIncludeDirectories>$(ProjectDir)..\libc;$(ProjectDir)..\newlib\newlib\libc\include;$(ProjectDir)..\include;$(ProjectDir)..\..\include;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <PreprocessorDefinitions>VK_BUILD_FOR_USERSPACE=1;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
  </ItemDefinitionGroup>
  <ItemGroup>
    <ClCompile Include="..\libc\crt0.c" />
    <ClCompile Include="hello.c" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\libc\libc.vcxproj">
      <Project>{7C8D9E0F-1234-4B5C-89DE-0123456789AC}</Project>
      <LinkLibraryDependencies>true</LinkLibraryDependencies>
      <UseLibraryDependencyInputs>true</UseLibraryDependencyInputs>
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
    </ProjectReference>
  </ItemGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>

