#ifndef VKCPP_SPAN_H
#define VKCPP_SPAN_H

#include <array>
#include <cstddef>
#include <type_traits>
#include <utility>

namespace std {

inline constexpr size_t dynamic_extent = static_cast<size_t>(-1);

template <typename T, size_t Extent = dynamic_extent>
class span {
public:
    using element_type = T;
    using value_type = remove_cv_t<T>;
    using size_type = size_t;
    using difference_type = ptrdiff_t;
    using pointer = element_type*;
    using const_pointer = const element_type*;
    using reference = element_type&;
    using const_reference = const element_type&;
    using iterator = pointer;
    using const_iterator = const_pointer;

    static constexpr size_type extent = Extent;

    constexpr span() noexcept : data_(nullptr), size_(0) {}

    constexpr span(pointer ptr, size_type count) noexcept
        : data_(ptr), size_(count) {}

    constexpr span(pointer first, pointer last) noexcept
        : data_(first), size_(static_cast<size_type>(last - first)) {}

    template <typename U, size_t N>
    constexpr span(U (&arr)[N]) noexcept
        : data_(arr), size_(N)
    {
        static_assert(Extent == dynamic_extent || Extent == N,
                      "span extent does not match array size");
    }

    template <typename U, size_t N>
    constexpr span(array<U, N>& arr) noexcept
        : data_(arr.data()), size_(N)
    {
        static_assert(Extent == dynamic_extent || Extent == N,
                      "span extent does not match array size");
    }

    template <typename U, size_t N>
    constexpr span(const array<U, N>& arr) noexcept
        : data_(arr.data()), size_(N)
    {
        static_assert(Extent == dynamic_extent || Extent == N,
                      "span extent does not match array size");
    }

    template <typename Container>
    constexpr span(Container& container) noexcept
        : data_(std::data(container)), size_(std::size(container)) {}

    template <typename Container>
    constexpr span(const Container& container) noexcept
        : data_(std::data(container)), size_(std::size(container)) {}

    constexpr auto begin() const noexcept -> iterator { return data_; }
    constexpr auto end() const noexcept -> iterator { return data_ + size_; }
    constexpr auto data() const noexcept -> pointer { return data_; }

    constexpr auto size() const noexcept -> size_type { return size_; }
    constexpr auto size_bytes() const noexcept -> size_type { return size_ * sizeof(element_type); }
    constexpr auto empty() const noexcept -> bool { return size_ == 0; }

    constexpr auto operator[](size_type index) const noexcept -> reference { return data_[index]; }
    constexpr auto front() const noexcept -> reference { return data_[0]; }
    constexpr auto back() const noexcept -> reference { return data_[size_ - 1]; }

    template <size_t Count>
    constexpr auto first() const noexcept -> span<element_type, Count>
    {
        return span<element_type, Count>(data_, Count);
    }

    template <size_t Count>
    constexpr auto last() const noexcept -> span<element_type, Count>
    {
        return span<element_type, Count>(data_ + size_ - Count, Count);
    }

    template <size_t Offset, size_t Count = dynamic_extent>
    constexpr auto subspan() const noexcept
        -> span<element_type,
                Count != dynamic_extent ? Count :
                (Extent != dynamic_extent ? Extent - Offset : dynamic_extent)>
    {
        const size_type count = Count == dynamic_extent ? size_ - Offset : Count;
        return span<element_type,
                    Count != dynamic_extent ? Count :
                    (Extent != dynamic_extent ? Extent - Offset : dynamic_extent)>(
            data_ + Offset,
            count);
    }

    constexpr auto first(size_type count) const noexcept -> span<element_type>
    {
        return span<element_type>(data_, count);
    }

    constexpr auto last(size_type count) const noexcept -> span<element_type>
    {
        return span<element_type>(data_ + size_ - count, count);
    }

    constexpr auto subspan(size_type offset, size_type count = dynamic_extent) const noexcept
        -> span<element_type>
    {
        const size_type actual_count = count == dynamic_extent ? size_ - offset : count;
        return span<element_type>(data_ + offset, actual_count);
    }

private:
    pointer data_;
    size_type size_;
};

template <typename T, size_t N>
span(T (&)[N]) -> span<T, N>;

template <typename T, size_t N>
span(array<T, N>&) -> span<T, N>;

template <typename T, size_t N>
span(const array<T, N>&) -> span<const T, N>;

}  // namespace std

#endif  // VKCPP_SPAN_H
