#ifndef VKCPP_LIMITS_H
#define VKCPP_LIMITS_H

#include <limits.h>
#include <time.h>

namespace std {

template <typename T>
struct numeric_limits {
    static constexpr T max() noexcept
    {
        return static_cast<T>(~static_cast<T>(0));
    }
};

template <>
struct numeric_limits<time_t> {
    static constexpr time_t max() noexcept
    {
        return static_cast<time_t>(LONG_MAX);
    }
};

}  // namespace std

#endif
