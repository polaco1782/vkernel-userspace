#ifndef VKCPP_INITIALIZER_LIST_H
#define VKCPP_INITIALIZER_LIST_H

#include <cstddef>

namespace std {

template <typename T>
class initializer_list {
public:
    using value_type = T;
    using reference = const T&;
    using const_reference = const T&;
    using size_type = size_t;
    using iterator = const T*;
    using const_iterator = const T*;

    constexpr initializer_list() noexcept : begin_(nullptr), size_(0) {}

    constexpr const T* begin() const noexcept { return begin_; }
    constexpr const T* end() const noexcept { return begin_ + size_; }
    constexpr size_t size() const noexcept { return size_; }

private:
    constexpr initializer_list(const T* begin, size_t size) noexcept
        : begin_(begin), size_(size) {}

    const T* begin_;
    size_t size_;
};

template <typename T>
constexpr const T* begin(initializer_list<T> values) noexcept
{
    return values.begin();
}

template <typename T>
constexpr const T* end(initializer_list<T> values) noexcept
{
    return values.end();
}

}  // namespace std

#endif  // VKCPP_INITIALIZER_LIST_H